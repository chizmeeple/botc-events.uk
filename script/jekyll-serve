#!/usr/bin/env bash

set -e

# Run from project root (where _config.yml and script/ live)
cd "$(dirname "$0")/.."

# do our best to source the correct chruby version
if [[ -d "/opt/homebrew/opt/chruby/share/chruby/" ]]; then
    # Ensure PROMPT_COMMAND is defined so chruby's hooks don't trip nounset
    if [[ -z "${PROMPT_COMMAND+x}" ]]; then
        PROMPT_COMMAND=""
    fi

    source "/opt/homebrew/opt/chruby/share/chruby/chruby.sh"
    source "/opt/homebrew/opt/chruby/share/chruby/auto.sh"
fi

if [ -f .ruby-version ]; then
    chruby "$(cat .ruby-version)"
fi

# make sure data is valid
ruby script/validate_clubs.rb

# Generate events data so club pages show upcoming events (same as deploy workflow)
ruby script/generate_events.rb || true

# validate events data
ruby script/validate_events.rb

# Build site so we can validate clubs.json output (catches invalid JSON e.g. from missing lat/lng)
bundle exec jekyll build --quiet

# validate built clubs.json
ruby script/validate_clubs_json.rb

# run the server (--source source restricts watch to source/ only, so changes to script/, README, etc. don't trigger rebuilds)
# --config _config.yml required: with --source, Jekyll looks for config in source/ by default; ours is at project root
bundle exec jekyll serve --source source --config _config.yml --livereload --livereload-min-delay 10 --strict_front_matter
