{
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Startup tasks",
        "dependsOn": ["Open Regular Terminal", "Jekyll Serve"],
        "dependsOrder": "parallel",
        "presentation": {
          "reveal": "always",
          "panel": "new",
          "group": "develop",
        },
        "runOptions": {
          "runOn": "folderOpen",
        },
        "problemMatcher": [],
      },
      {
        "label": "Jekyll Serve",
        "type": "shell",
        "command": "script/jekyll-serve",
        "isBackground": true,
        "problemMatcher": [],
        "presentation": {
          "reveal": "always",
          "panel": "new",
          "group": "startup",
        },
        "group": {
          "kind": "test",
          "isDefault": true,
        },
      },
      {
        "label": "Open Regular Terminal",
        "type": "shell",
        "command": "/usr/bin/env zsh",
        "presentation": {
          "reveal": "always",
          "panel": "new",
          "group": "startup",
        },
        "runOptions": {
          "runOn": "folderOpen",
        },
        "isBackground": true,
        "problemMatcher": [],
      },
    ],
  },
  "folders": [
    {
      "name": "source",
      "path": "./source",
    },
    {
      "name": "groups",
      "path": "./source/_clubs",
    },
    {
      "name": "github",
      "path": "./.github",
    },
    {
      "name": "project-root",
      "path": "./",
    },
  ],
  "settings": {
    "files.exclude": {
      "**/_site": true,
      "**/.github": true,
      "source": true,
      "Gemfile.lock": true,
    },
  },
}
