---
layout: null
---
[
{% assign comma = false %}
{% for club in site.clubs %}
  {% if comma %},{% endif %}
  {% assign comma = true %}
  {
    "name": {{ club.name | jsonify }},
    "slug": {{ club.slug | jsonify }},
    "url": {{ club.url | relative_url | jsonify }},
    "based_in": {{ club.based_in | jsonify }},
    {% assign event_data = site.data.rendered_events.by_slug[club.slug] %}
    "pills": {% if event_data.pills %}{{ event_data.pills | jsonify }}{% else %}null{% endif %},
    "locations": {% if event_data.locations %}{{ event_data.locations | jsonify }}{% else %}[]{% endif %},
    "event_days": {% if event_data.event_days %}{{ event_data.event_days | jsonify }}{% else %}[]{% endif %},
    "age_restriction": {{ club.age_restriction | jsonify }},
    "website": {{ club.website | jsonify }},
    "meetup": {{ club.meetup | jsonify }},
    "facebook": {{ club.facebook | jsonify }},
    "description": {{ club.description | jsonify }},
    "image": {{ club.image | jsonify }}
  }
{% endfor %}
{% for slug in site.data.rendered_special_events.map_slugs %}
  {% assign se_data = site.data.rendered_special_events.by_slug[slug] %}
  {% if se_data %}
  {% if comma %},{% endif %}
  {% assign comma = true %}
  {% assign se_img = se_data.banner_image %}
  {% if se_img == blank %}
    {% assign se_img = se_data.image %}
  {% endif %}
  {
    "kind": "special",
    "name": {{ se_data.eventname | jsonify }},
    "slug": {{ slug | jsonify }},
    "url": {{ '/special/' | append: slug | append: '/' | relative_url | jsonify }},
    "based_in": {{ se_data.based_in | jsonify }},
    "pills": null,
    "locations": {{ se_data.locations | jsonify }},
    "event_days": {{ se_data.event_days | jsonify }},
    "age_restriction": null,
    "website": {{ se_data.website | jsonify }},
    "meetup": null,
    "facebook": null,
    "description": {{ se_data.description | jsonify }},
    "image": {{ se_img | jsonify }}
  }
  {% endif %}
{% endfor %}
]
